# Environment Configuration Template
# IMPORTANT: Copy this file to 'environment.env' and fill in your actual values
# NEVER commit environment.env to git - it contains sensitive credentials

# Application URL
Base_Url=http://orangehrm.qedgetech.com/

# Login credentials
# NOTE: If your password contains # or other special characters, wrap it in quotes
Base_User=Admin
Base_Pass="YOUR_PASSWORD_HERE"

# Add other environment-specific variables below
# Environment types: dev, qa, staging, prod
# ENVIRONMENT=qa
